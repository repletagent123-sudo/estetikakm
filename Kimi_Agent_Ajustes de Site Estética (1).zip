  <!-- WhatsApp Flutuante -->
  <a href="https://wa.me/5511953429077?text=Olá!%20Quero%20saber%20mais%20sobre%20o%20site%20profissional%20para%20minha%20clínica%20de%20estética" target="_blank" rel="noopener noreferrer" class="fixed bottom-6 right-6 z-50 bg-emerald-500 hover:bg-emerald-600 text-white p-4 rounded-full shadow-2xl hover:scale-110 transition-all duration-300 pulse-glow" aria-label="WhatsApp">
    <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>

  <script>
    // Scripts mantidos iguais
    document.addEventListener('DOMContentLoaded', () => {
      initHorarios();
      initDateValidation();
      renderAgendamentos();
      renderEstoque();
      initDefaultStock();
    });

    function toggleMobileMenu() {
      const menu = document.getElementById('mobileMenu');
      menu.classList.toggle('hidden');
    }

    function initHorarios() {
      const select = document.getElementById('hora');
      const horarios = [];
      for (let h = 8; h <= 18; h++) {
        const hora = h.toString().padStart(2, '0');
        horarios.push(`${hora}:00`);
        if (h !== 18) horarios.push(`${hora}:30`);
      }
      horarios.forEach(h => {
        const opt = document.createElement('option');
        opt.value = h;
        opt.textContent = h;
        select.appendChild(opt);
      });
    }

    function initDateValidation() {
      const input = document.getElementById('data');
      const hoje = new Date();
      const amanha = new Date(hoje);
      amanha.setDate(amanha.getDate() + 1);
      
      input.min = formatDateISO(amanha);
      const maxDate = new Date(hoje);
      maxDate.setDate(maxDate.getDate() + 60);
      input.max = formatDateISO(maxDate);

      input.addEventListener('change', () => {
        const data = new Date(input.value + 'T12:00:00');
        const diaSemana = data.getDay();
        const erro = document.getElementById('dataErro');
        
        if (diaSemana === 0) {
          erro.classList.remove('hidden');
          input.value = '';
        } else {
          erro.classList.add('hidden');
        }
      });
    }

    function formatDateISO(date) {
      return date.toISOString().split('T')[0];
    }

    function handleAgendamento(e) {
      e.preventDefault();
      
      const nome = document.getElementById('nome').value.trim();
      const telefone = document.getElementById('telefone').value.trim();
      const procedimento = document.getElementById('procedimento').value;
      const data = document.getElementById('data').value;
      const hora = document.getElementById('hora').value;

      if (!nome || !telefone || !procedimento || !data || !hora) {
        showToast('Preencha todos os campos!', 'error');
        return;
      }

      const dataObj = new Date(data + 'T12:00:00');
      if (dataObj.getDay() === 0) {
        showToast('Não atendemos aos domingos!', 'error');
        return;
      }

      const agendamento = {
        id: Date.now(),
        nome, telefone, procedimento, data, hora,
        criadoEm: new Date().toLocaleString('pt-BR')
      };
      
      const agendamentos = JSON.parse(localStorage.getItem('esteticaPro_agendamentos') || '[]');
      agendamentos.unshift(agendamento);
      localStorage.setItem('esteticaPro_agendamentos', JSON.stringify(agendamentos));

      const msg = `*🌸 Novo Agendamento - Estética Pro*%0A%0A` +
        `*Nome:* ${nome}%0A` +
        `*Telefone:* ${telefone}%0A` +
        `*Serviço:* ${procedimento}%0A` +
        `*Data:* ${formatarDataBR(data)}%0A` +
        `*Horário:* ${hora}%0A%0A` +
        `Aguardo confirmação! ✅`;

      const url = `https://wa.me/5511953429077?text=${msg}`;
      window.open(url, '_blank');

      e.target.reset();
      renderAgendamentos();
      showToast('Agendamento enviado via WhatsApp!');
    }

    function formatarDataBR(dataISO) {
      const [ano, mes, dia] = dataISO.split('-');
      return `${dia}/${mes}/${ano}`;
    }

    function toggleAdmin() {
      const panel = document.getElementById('adminPanel');
      if (panel) {
        panel.classList.toggle('hidden');
        if (!panel.classList.contains('hidden')) {
          renderAgendamentos();
          renderEstoque();
        }
      }
    }

    function switchTab(tab) {
      document.getElementById('tab-agendamentos').className = tab === 'agendamentos' 
        ? 'flex-1 px-4 py-3 text-sm font-semibold text-slate-900 border-b-2 border-indigo-500 bg-indigo-50'
        : 'flex-1 px-4 py-3 text-sm font-semibold text-slate-500 border-b-2 border-transparent hover:text-slate-700';
      document.getElementById('tab-estoque').className = tab === 'estoque'
        ? 'flex-1 px-4 py-3 text-sm font-semibold text-slate-900 border-b-2 border-indigo-500 bg-indigo-50'
        : 'flex-1 px-4 py-3 text-sm font-semibold text-slate-500 border-b-2 border-transparent hover:text-slate-700';

      document.getElementById('content-agendamentos').classList.toggle('hidden', tab !== 'agendamentos');
      document.getElementById('content-estoque').classList.toggle('hidden', tab !== 'estoque');
    }

    function renderAgendamentos() {
      const agendamentos = JSON.parse(localStorage.getItem('esteticaPro_agendamentos') || '[]');
      const countEl = document.getElementById('countAgendamentos');
      if (countEl) countEl.textContent = `${agendamentos.length} registro${agendamentos.length !== 1 ? 's' : ''}`;
      
      const tbody = document.getElementById('tabelaAgendamentos');
      if (!tbody) return;
      
      if (agendamentos.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" class="px-4 py-8 text-center text-slate-400">Nenhum agendamento registrado</td></tr>';
        return;
      }

      tbody.innerHTML = agendamentos.map(a => `
        <tr class="hover:bg-slate-50 transition">
          <td class="px-4 py-3 font-medium text-slate-900">${formatarDataBR(a.data)}<br><span class="text-xs text-slate-500">${a.hora}</span></td>
          <td class="px-4 py-3">${a.nome}</td>
          <td class="px-4 py-3"><span class="px-2 py-1 bg-pink-100 text-pink-700 rounded-md text-xs font-semibold">${a.procedimento}</span></td>
          <td class="px-4 py-3 text-slate-500">${a.telefone}</td>
          <td class="px-4 py-3 text-center">
            <button onclick="deleteAgendamento(${a.id})" class="text-red-500 hover:text-red-700 transition p-1">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            </button>
          </td>
        </tr>
      `).join('');
    }

    function deleteAgendamento(id) {
      let agendamentos = JSON.parse(localStorage.getItem('esteticaPro_agendamentos') || '[]');
      agendamentos = agendamentos.filter(a => a.id !== id);
      localStorage.setItem('esteticaPro_agendamentos', JSON.stringify(agendamentos));
      renderAgendamentos();
      showToast('Agendamento removido');
    }

    function clearAgendamentos() {
      if (confirm('Tem certeza que deseja apagar TODOS os agendamentos?')) {
        localStorage.removeItem('esteticaPro_agendamentos');
        renderAgendamentos();
        showToast('Todos os agendamentos foram removidos');
      }
    }

    function initDefaultStock() {
      if (!localStorage.getItem('esteticaPro_estoque')) {
        const defaultStock = [
          { id: 1, nome: 'Creme Hidratante Facial', quantidade: 12, status: 'Disponível' },
          { id: 2, nome: 'Máscara de Argila Verde', quantidade: 3, status: 'Alerta de Reposição' },
          { id: 3, nome: 'Luvas de Procedimento', quantidade: 8, status: 'Disponível' },
          { id: 4, nome: 'Agulhas para Botox', quantidade: 25, status: 'Disponível' },
          { id: 5, nome: 'Ácido Hialurônico', quantidade: 2, status: 'Alerta de Reposição' },
        ];
        localStorage.setItem('esteticaPro_estoque', JSON.stringify(defaultStock));
      }
    }

    function renderEstoque() {
      const estoque = JSON.parse(localStorage.getItem('esteticaPro_estoque') || '[]');
      const tbody = document.getElementById('tabelaEstoque');
      if (!tbody) return;
      
      if (estoque.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" class="px-4 py-8 text-center text-slate-400">Nenhum produto cadastrado</td></tr>';
        return;
      }

      tbody.innerHTML = estoque.map(p => {
        const statusClass = p.status === 'Disponível' 
          ? 'bg-emerald-100 text-emerald-700' 
          : 'bg-amber-100 text-amber-700';
        return `
        <tr class="hover:bg-slate-50 transition">
          <td class="px-4 py-3 font-medium text-slate-900">${p.nome}</td>
          <td class="px-4 py-3 text-center font-bold ${p.quantidade <= 5 ? 'text-red-500' : 'text-slate-700'}">${p.quantidade} un</td>
          <td class="px-4 py-3 text-center"><span class="px-2 py-1 rounded-md text-xs font-semibold ${statusClass}">${p.status}</span></td>
          <td class="px-4 py-3 text-center">
            <div class="flex items-center justify-center gap-2">
              <button onclick="editStock(${p.id}, 1)" class="text-emerald-600 hover:text-emerald-800 p-1" title="Adicionar">+</button>
              <button onclick="editStock(${p.id}, -1)" class="text-red-500 hover:text-red-700 p-1" title="Remover">−</button>
              <button onclick="deleteProduct(${p.id})" class="text-slate-400 hover:text-red-500 p-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </div>
          </td>
        </tr>
      `}).join('');
    }

    function openAddProduct() {
      const form = document.getElementById('addProductForm');
      if (form) form.classList.remove('hidden');
      document.getElementById('produtoNome').focus();
    }

    function closeAddProduct() {
      const form = document.getElementById('addProductForm');
      if (form) form.classList.add('hidden');
      document.getElementById('produtoNome').value = '';
      document.getElementById('produtoQtd').value = '';
      document.getElementById('produtoStatus').value = 'Disponível';
    }

    function addProduct() {
      const nome = document.getElementById('produtoNome').value.trim();
      const qtd = parseInt(document.getElementById('produtoQtd').value);
      const status = document.getElementById('produtoStatus').value;

      if (!nome || isNaN(qtd) || qtd < 0) {
        showToast('Preencha todos os campos corretamente!', 'error');
        return;
      }

      const estoque = JSON.parse(localStorage.getItem('esteticaPro_estoque') || '[]');
      estoque.push({
        id: Date.now(),
        nome,
        quantidade: qtd,
        status
      });
      localStorage.setItem('esteticaPro_estoque', JSON.stringify(estoque));
      closeAddProduct();
      renderEstoque();
      showToast('Produto adicionado ao estoque!');
    }

    function editStock(id, delta) {
      const estoque = JSON.parse(localStorage.getItem('esteticaPro_estoque') || '[]');
      const produto = estoque.find(p => p.id === id);
      if (!produto) return;

      produto.quantidade = Math.max(0, produto.quantidade + delta);
      if (produto.quantidade <= 5) {
        produto.status = 'Alerta de Reposição';
      } else {
        produto.status = 'Disponível';
      }

      localStorage.setItem('esteticaPro_estoque', JSON.stringify(estoque));
      renderEstoque();
    }

    function deleteProduct(id) {
      if (!confirm('Remover este produto do estoque?')) return;
      let estoque = JSON.parse(localStorage.getItem('esteticaPro_estoque') || '[]');
      estoque = estoque.filter(p => p.id !== id);
      localStorage.setItem('esteticaPro_estoque', JSON.stringify(estoque));
      renderEstoque();
      showToast('Produto removido');
    }

    function showToast(msg, type = 'success') {
      const toast = document.getElementById('toast');
      const toastMsg = document.getElementById('toastMsg');
      if (!toast || !toastMsg) return;
      
      toastMsg.textContent = msg;
      
      if (type === 'error') {
        toast.querySelector('svg').classList.replace('text-emerald-400', 'text-red-400');
        toast.querySelector('svg').innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>';
      } else {
        toast.querySelector('svg').classList.replace('text-red-400', 'text-emerald-400');
        toast.querySelector('svg').innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>';
      }

      toast.classList.remove('translate-x-full');
      setTimeout(() => {
        toast.classList.add('translate-x-full');
      }, 3000);
    }
  </script>
</body>
</html>
